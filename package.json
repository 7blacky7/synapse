{
  "name": "synapse",
  "version": "0.1.0",
  "description": "KI-Gedaechtnis & Code-Intelligenz - Verbindet lokale CLIs und Web-KIs",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "build:core": "pnpm --filter @synapse/core run build",
    "build:mcp": "pnpm --filter @synapse/mcp-server run build",
    "build:api": "pnpm --filter @synapse/rest-api run build",
    "dev:mcp": "pnpm --filter @synapse/mcp-server run dev",
    "dev:api": "pnpm --filter @synapse/rest-api run dev",
    "lint": "eslint packages/*/src --ext .ts",
    "clean": "rimraf packages/*/dist"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "rimraf": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
