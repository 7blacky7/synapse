# ===========================================
# SYNAPSE KONFIGURATION
# ===========================================

# PostgreSQL (Source of Truth)
DATABASE_URL=postgresql://synapse:password@localhost:5432/synapse

# Qdrant Vektor-Datenbank
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Embedding Provider: "google", "ollama", "openai"
EMBEDDING_PROVIDER=google

# Google Gemini (empfohlen, 3072d)
GOOGLE_API_KEY=

# Ollama (lokal)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# OpenAI (optional)
OPENAI_API_KEY=

# Context7 (Framework-Docs Auto-Fetch)
CONTEXT7_API_KEY=

# ===========================================
# REST API
# ===========================================
API_PORT=3456
API_HOST=0.0.0.0

# ===========================================
# DATEI-VERARBEITUNG
# ===========================================
MAX_FILE_SIZE_MB=1
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
DEBOUNCE_MS=500
